# Configuración de MartaBot
# Copiá este archivo como .env.local y completá tus credenciales

# Google Sheets API
# Para obtener estas credenciales:
# 1. Ir a https://console.cloud.google.com
# 2. Crear un proyecto nuevo o usar uno existente
# 3. Habilitar la API de Google Sheets
# 4. Crear credenciales de tipo "Service Account"
# 5. Descargar el JSON y copiar los valores aquí

GOOGLE_CLIENT_EMAIL=tu-service-account@tu-proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_CLAVE_PRIVADA_AQUI\n-----END PRIVATE KEY-----\n"

# IDs de tus Google Sheets (los sacás de la URL de cada planilla)
# Ejemplo: https://docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit
SHEET_MASTER_ID=1TmEDhSznW0XgUUETm2aP_0g_rDopW7ZVTbxm3QavDro
SHEET_CONTACTS_ID=155y_ulSsCpBx1Lm2x5pHZ8MSFttrYD44tQGUPk73VhI
SHEET_PRODUCTS_ID=1ou2hHA5yB29fCF8smO0xC1PlboDlTgiBu3ryNrf1n8w
SHEET_NOTES_ID=18ozoqFzOXa56OdTqVE8t42A3i3c1tQ6Gr7SZH5ua3qk
PROFORMAS_FOLDER_ID=1_0X0Z1v_N0u_pX-qO6D2y_I_8_I_I_I

# Google Drive Templates y Carpetas
TEMPLATE_ID=1x8717Fb4aPWIzi_-mtRC1ItnK9HPEm_tg1z66o_I248
PO_TEMPLATE_ID=1U6vF9Ec5X1z4kGdcEqBEMho-WkmWe6xqT1ZhhEzzBHs
OPERATIONS_ROOT_FOLDER_ID=1gIVhf5UWYRRMaUOv4Xou4msSfA4-jAC2

# Para OAuth (Opcional, si no usás Service Account)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REFRESH_TOKEN=...
NEXTAUTH_URL=http://localhost:3000

# OpenAI API (para el chat con Marta)
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Resend API (para enviar emails)
# Obtener en: https://resend.com/api-keys
RESEND_API_KEY=re_...
